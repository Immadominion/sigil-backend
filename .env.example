# Sigil Backend Configuration

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/sigil

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ISSUER=sigil
JWT_EXPIRY=7d

# Encryption (32 bytes hex = 64 hex chars)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-random-64-hex-char-string

# Seal Program
SEAL_PROGRAM_ID=EV3TKRVz7pTHpAqBTjP8jmwuvoRBRCpjmVSPHhcMnXqb

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# CORS — allowed frontend origin
FRONTEND_ORIGIN=http://localhost:8081
